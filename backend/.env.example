# Better Waseda Moodle 改 - バックエンド環境変数
# Vercel のダッシュボードで以下を設定してください

# Stripe シークレットキー（Stripe ダッシュボード > Developers > API keys）
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY

# Anthropic Claude API キー（再発行したものを使用）
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_NEW_KEY

# Slack Incoming Webhook URL（api.slack.com/apps で取得）
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# このバックエンドのデプロイ後 URL（Vercel が割り当てるもの）
BASE_URL=https://bwm-inquiry-api.vercel.app
